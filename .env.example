# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/linkinbio"

# ─── NextAuth ────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with: openssl rand -base64 32"

# ─── Google OAuth ─────────────────────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Paystack ────────────────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_..."
# Create these plans in your Paystack dashboard → Subscriptions → Plans
PAYSTACK_PLAN_CREATOR_MONTHLY="PLN_xxxxxxxxxxxx"
PAYSTACK_PLAN_PRO_MONTHLY="PLN_xxxxxxxxxxxx"

# ─── Termii (SMS OTP) ────────────────────────────────────────
TERMII_API_KEY=""
TERMII_SENDER_ID="N-Linker"       # registered sender ID

# ─── Image Storage (pick one) ────────────────────────────────
# Option A: Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Option B: Supabase Storage
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LinkNG"
